{
  "root": true,
  "env": { "es2021": true, "node": true },
  "parserOptions": { "ecmaVersion": 2021, "sourceType": "module" },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-undef": "error"
  },
  "ignorePatterns": ["dist/**"]
}

